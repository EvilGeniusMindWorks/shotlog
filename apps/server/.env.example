# Postgres connection — Railway injects this automatically when you add a
# Postgres service and reference it: ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:pass@host:5432/shotlog"

# JWT signing secret — generate with: openssl rand -base64 48
JWT_SECRET=""

# Bootstrap account (created on first boot if it doesn't exist)
ADMIN_EMAIL="mark@baystateblasting.com"
ADMIN_PASSWORD=""
ADMIN_NAME="Mark Swihart"

PORT=4000
