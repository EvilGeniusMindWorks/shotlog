// ShotLog sync server — Postgres via Prisma.
//
// Design note: synced records are stored as JSONB documents keyed by
// (userId, tableName, recordId) rather than mirroring the client's 17
// tables relationally. For v1, sync = durable backup with last-write-wins;
// a document store survives client schema evolution without server
// migrations. Relational projections can be added when reporting or
// multi-user querying needs them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String       @id @default(uuid())
  name      String
  createdAt DateTime     @default(now())
  users     User[]
  records   SyncRecord[]
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String
  /// admin | blaster | driller | mechanic | office
  role          String         @default("blaster")
  isActive      Boolean        @default(true)
  /// Personal blasting licenses: [{state, licenseNumber, expirationDate}] —
  /// one per state; travels with the login session for offline auto-fill
  licenses      Json           @default("[]")
  /// Signature on file: PNG data URL, offered at blast-log sign-off
  signature     String?
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]

  @@index([companyId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model SyncRecord {
  /// Company-scoped: every user in the company shares the same records
  companyId String
  tableName String
  recordId  String
  /// Client-side updatedAt — the LWW clock
  updatedAt DateTime
  deletedAt DateTime?
  payload   Json
  /// Server receive time (audit)
  syncedAt  DateTime  @default(now())
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, tableName, recordId])
  @@index([companyId, updatedAt])
}
